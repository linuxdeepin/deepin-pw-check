#: lib/deepin_pw_check.c:723
msgid "Checking successful"
msgstr "შემოწმება წარმატებულია"

#: lib/deepin_pw_check.c:725
msgid "The password cannot be empty"
msgstr "პაროლი ცარიელი ვერ იქნება"

#: lib/deepin_pw_check.c:731 lib/deepin_pw_check.c:767
#, c-format
msgid ""
"Minimum of %d characters. At least %d types: 0-9, a-z, A-Z and symbols. "
"Different from the username."
msgstr ""
"მინიმუმ %d სიმბოლო. სულ ცოტა %d ტიპის: 0-9, a-z, A-Z და სიმბოლოები, "
"განსხვავებული მომხმარებლის სახელიდან."

#: lib/deepin_pw_check.c:735
#, c-format
msgid "Password must be no more than %d characters"
msgstr "პაროლი, სულ ცოტა, %d სიმბოლოს უნდა შეიცავდეს"

#: lib/deepin_pw_check.c:739
msgid ""
"Password can only contain English letters (case-sensitive), numbers or "
"special symbols (~`!@#$%^&*()-_+=|\\{}[]:\"'<>,.?/)"
msgstr ""
"პაროლი შეიძლება, მხოლოდ, შეიცავდეს ინგლისურ ასოებს (დიდ და პატარა "
"ასოებს მნიშვნელობა აქვს), ციფრებს და სპეციალურ სიმბოლოებს (~`!@#$%^&*()-"
"_+=|\\{}[]:\"'<>,.?/)"

#: lib/deepin_pw_check.c:745
#, c-format
msgid "Password must not contain more than %d palindrome characters"
msgstr "პაროლი არ უნდა შეიცავდეს %d-ზე მეტ პალინდრომულ სიმბოლოს"

#: lib/deepin_pw_check.c:749 lib/deepin_pw_check.c:751
#: lib/deepin_pw_check.c:753
msgid "Create a strong password please"
msgstr "შექმენით ძლიერი პაროლი, გეთაყვა"

#: lib/deepin_pw_check.c:755
msgid "Do not use common words and combinations as password"
msgstr "ნუ გამოიყენებთ ზოგად სიტყვებს და მათ კომბინაციებს პაროლად"

#: lib/deepin_pw_check.c:757
msgid "Parameter options are invalid"
msgstr "პარამეტრის არჩევნები არასწორია"

#: lib/deepin_pw_check.c:759
msgid "Internal error"
msgstr "შიდა შეცდომა"

#: lib/deepin_pw_check.c:761
msgid "Invalid user"
msgstr "არასწორი მომხმარებელი"

#: lib/deepin_pw_check.c:770
msgid "It does not meet password rules"
msgstr "პაროლი სირთულის მოთხოვნებს არ აკმაყოფილებს"

#: lib/deepin_pw_check.c:772
msgid "Invalid error type"
msgstr "არასწორი შეცდომის ტიპი"
